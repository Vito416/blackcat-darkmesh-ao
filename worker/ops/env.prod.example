# Production Worker (fail-closed defaults)

# Required secrets (must be set via wrangler secrets / vault). Runtime rejects placeholders.
FORGET_TOKEN=
WORKER_AUTH_TOKEN=
INBOX_HMAC_SECRET=
NOTIFY_HMAC_SECRET=

# Signature enforcement
INBOX_HMAC_OPTIONAL=0
NOTIFY_HMAC_OPTIONAL=0
AUTH_REQUIRE_SIGNATURE=1
AUTH_REQUIRE_NONCE=1
REQUIRE_SECRETS=1
REQUIRE_METRICS_AUTH=1

# Metrics auth (choose bearer or basic)
METRICS_BEARER_TOKEN=
# METRICS_BASIC_USER=
# METRICS_BASIC_PASS=

# Rate limits / replay (tuned for prod SLA ~5 rps/IP; raise if needed)
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60
NOTIFY_RATE_MAX=20
NOTIFY_RATE_WINDOW=60
REPLAY_TTL=600
SUBJECT_MAX_ENVELOPES=10
PAYLOAD_MAX_BYTES=65536

# Notification
NOTIFY_FROM=no-reply@example.com
# Optional destinations (one of):
# NOTIFY_WEBHOOK=https://example.com/hook
# SENDGRID_KEY=SG.xxxxxx
NOTIFY_RETRY_MAX=3
NOTIFY_RETRY_BACKOFF_MS=300
NOTIFY_BREAKER_THRESHOLD=5
NOTIFY_BREAKER_COOLDOWN=300
NOTIFY_DEDUPE_TTL=300

# Cron / scheduled
TEST_IN_MEMORY_KV=0

# Observability
METRICS_PROM_PATH=/tmp/worker-metrics.prom
# Set to 1 to disable metrics writes (testing only)
# METRICS_DISABLED=0

# Load test target (optional; only for k6/local tooling, never read in production code)
# WORKER_BASE_URL=https://<your-worker>.workers.dev
